# CORTANA main configuration — GDD §16.
# Production copy lives at /etc/cortana/cortana.yaml.
#
# RELOAD SCOPE: every key carries a reload class in the declarative schema
# (brain/cortana/config_schema.py — the single source of truth):
#   hot     — live on `systemctl reload cortana-brain` (most thresholds,
#             weights, windows, channel/role ids, tts lines, chat knobs)
#   sighup  — applied by an explicit reload step (tts.personality,
#             chat.enabled / chat.api_key_file) or a live rebuild through the
#             wake model pool (wake.model, wake.extra_models, wake.vad_threshold)
#   engine  — rebuilds the gazetteer/routing engine on reload
#   restart — bound at startup: stt.* (backend/model/threads/watchdog_s),
#             capture.vad_aggressiveness, ipc.socket, database.path,
#             discord.token_file, discord.guild_id
# Reload validates cortana.yaml + gazetteer.yaml + routing.yaml TOGETHER and
# swaps all-or-nothing; restart-bound edits are reported as "restart
# pending", never silently absorbed. Unknown/misspelled keys are REJECTED.
# Validate an edit before restarting:  python -m cortana.doctor --config <file>
#
# Every tunable in the system lives here; code contains no magic numbers.
# The numeric defaults below are starting values tuned from real fleet audio —
# expect them to move (see CLAUDE.md conventions).

discord:
  token_file: /etc/cortana/token          # dev fallback ONLY (0600, root:aura). Production
                                       # reads $CREDENTIALS_DIRECTORY/token via systemd
                                       # LoadCredential= — the token is never in this file.
  guild_id: 000000000000000000         # the corp's guild (snowflake)
  channels:
    intel_alerts: 000000000000000000   # only incidents that mention a role (GDD §11.2)
    intel_live:   000000000000000000   # every incident, no mentions — the firehose
    health:       000000000000000000   # hourly self-reports and degradation alerts
    transcript:   0                    # OPTIONAL STT review log (GDD §8.7): one line per
                                       # heard utterance — what she thinks she heard + how
                                       # it parsed — for reviewing phrasing/misfires. 0 = off
  roles:                               # OPTIONAL — leave keys out (or the whole
                                       # section) to run without role gates
    pilot: 000000000000000000          # gate: only members with this role may trigger
                                       # mentions. Unset/0 = anyone may
    fc:    000000000000000000          # gate: only this role may voice-trigger under
                                       # fleetmode (and use admin commands without
                                       # Manage Guild). Unset/0 = fleetmode restricts nobody
  watch_voice_channels: [000000000000000000]  # voice channels CORTANA watches / auto-joins
  auto_join: true                      # join when a pilot enters, leave when empty
  mentions_enabled: true               # false = silent mode: post cards, ping nobody
  here_on_severity: [high]             # ping @here by threat colour: high=RED, medium=ORANGE
  join_announcement: daily             # §19 consent notice on voice join:
                                       #   every = post on every join
                                       #   daily = at most once per 24h (survives
                                       #           restarts — stops rejoin spam)
                                       #   off   = never (consent posture carried
                                       #           by /optout + pinned docs)

wake:
  # The phrase itself ("hey cortana", GDD §5.2) is baked into the trained
  # model below — changing it means training a new model, not editing config.
  model:  /opt/cortana/models/wake/hey_cortana.onnx  # trained openWakeWord ONNX chain
  extra_models: []                     # additional openWakeWord ONNX chains scored in
                                       # parallel — ANY listed phrase wakes CORTANA
                                       # (e.g. keep hey_jarvis alongside a new custom
                                       # phrase through a transition). The threshold
                                       # below applies to the MAX score across models.
                                       # A broken/missing extra is logged once and
                                       # skipped; only a broken PRIMARY disables wake.
                                       # Every extra adds its own false-fire budget —
                                       # keep the total to 2-3 models (GDD §5.2).
  threshold: 0.55                      # wake score needed to open a capture window.
                                       # The trigger is single-frame (no debounce): below
                                       # ~0.45 ambient chatter false-fires constantly, and
                                       # every false wake is an STT decode + a junk relay.
  refractory_ms: 2000                  # per-user dead time after a wake hit
  vad_threshold: 0.0                   # OPT-IN Silero VAD gate inside openWakeWord:
                                       # >0 means a wake trigger only counts when
                                       # speech is detected simultaneously (cuts
                                       # false fires from music/game audio). It once
                                       # silently killed the wake word when enabled
                                       # by default — try ~0.3-0.5 and VERIFY wake
                                       # still fires. Applied at model build; the
                                       # pool rebuilds live on reload.
  ack: beep                            # how CORTANA acknowledges the wake word:
                                       #   voice = speak "Go ahead." (talks back)
                                       #   beep  = instant tone (no synth latency)
                                       #   none  = silent


dialog:                                # voice dialog engine (GDD §5.4) — OPTIONAL
                                       # section; defaults are the tuned live values
  window_ms: 4000                      # wall-clock lifetime of a wake-free window
                                       # (say-again retry / "code <colour>" opener /
                                       # bare "command override"); DTX-proof
  ack_grace_ms: 2000                   # endpoint grace after a capture opens or a
                                       # prompt is spoken — cue playback + reaction
  endpoint_gap_floor_ms: 700           # floor under capture.endpoint_silence_ms:
                                       # DTX drops packets between words, a
                                       # too-eager gap clips pilots mid-sentence
  max_retries: 2                       # wake-free windows per dialog TOTAL (subdialog
                                       # openers and say-again retries share it);
                                       # only a fresh wake refills the budget —
                                       # exhaustion ends audibly with "standing down"
  confirm_reports: low                 # confirm-first for voice reports (GDD §8.3):
                                       # off = commit immediately (readback only);
                                       # low = uncertain matches ask "Heard X — confirm?";
                                       # always = every voice report asks.
                                       # yes commits · no re-opens "say again" ·
                                       # SILENCE COMMITS ANYWAY (distress is never lost)
  retry_min_logprob: -1.3              # transcripts below this Whisper confidence are
                                       # chatter/noise: no say-again retry, the dialog
                                       # closes silently ("stuck open in comms chatter"
                                       # loop). Commands are never gated by this.
                                       # Say "end transmission" / "disregard" /
                                       # "never mind" / "stand down" to close any
                                       # open dialog by voice at any time.

capture:
  preroll_ms: 300                      # RAM ring-buffer audio prepended to each capture
  endpoint_silence_ms: 1000            # trailing silence that ends an utterance —
                                       # ALSO the wall-clock gap for Discord's DTX
                                       # (packets stop during pauses; floor 700ms).
                                       # 400 clipped pilots at natural thinking
                                       # pauses; 1000 costs ~+0.3s per command and
                                       # lets mid-question pauses survive.
  max_utterance_ms: 12000              # hard cap on a single capture window.
                                       # 6000 truncated long override questions;
                                       # reports still end early at the silence
                                       # endpoint, so short commands stay fast.
  vad_aggressiveness: 2                # webrtcvad mode, 0 (permissive) – 3 (aggressive)
  streaming: true                      # LIVE RECOGNITION (GDD §5.5): decode the growing
                                       # capture WHILE the pilot is still talking and commit
                                       # the instant a complete, confident command is present
                                       # — instead of waiting for them to stop before the
                                       # first decode. This is the fix for the "keep talking
                                       # and it drags 10-20s" latency. Each incremental decode
                                       # is a real Whisper run, so it needs a dedicated
                                       # >=4-vCPU box; set false on a 2-vCPU droplet.
  partial_decode_ms: 1200              # minimum new speech between incremental decodes
                                       # (the rate limiter). Lower = snappier + more CPU.
  partial_min_speech_ms: 900           # don't decode a fragment shorter than this — it can't
                                       # carry a whole command, and decoding it risks a clip.
  early_commit_min_logprob: -1.0       # an incremental decode below this confidence keeps
                                       # listening rather than clipping the pilot; the normal
                                       # silence endpoint still catches it.

stt:
  backend: faster-whisper              # or: whisper-cpp (same Transcriber protocol)
  model: small                         # Whisper model size
  compute_type: int8                   # CTranslate2 quantization
  cpu_threads: 2                       # Whisper decode threads. On a dedicated >=4-vCPU box, 2
                                       # gives snappy decodes (incl. streaming's incremental
                                       # ones) while the high-CPUWeight Ears mixer keeps its
                                       # cores. On a 2-vCPU box use 1: there, 2 starves the
                                       # real-time mixer and her voice goes choppy (GDD §12/§17).
  bias_with_gazetteer: true            # bias Whisper toward gazetteer system names (hotwords,
                                       # or initial_prompt on older faster-whisper) — one channel,
                                       # hard-capped so a wide include_all prompt can't overflow
                                       # the decoder's 448-token position limit
  whisper_cpp_url: http://127.0.0.1:8080/inference  # used only when backend: whisper-cpp
  watchdog_s: 15                       # hang watchdog (GDD §20): seconds one decode may run
                                       # once it reaches the head of the STT queue before the
                                       # worker is respawned. Queue WAIT never counts (overload
                                       # is not a hang). After 2 consecutive respawns STT
                                       # latches degraded until reload/restart. Restart-only.
  relay_min_logprob: -0.9              # freeform relays below this Whisper confidence are
                                       # dropped with "Say again" instead of posted (GDD §8.6);
                                       # recognised commands are never gated by this.
  relay_mode: framed                   # what unmatched speech may become a relay card (§8.6):
                                       #   framed = only explicitly framed intel — a "report …"
                                       #            opener, a spoken colour code, or an
                                       #            all-hands phrase. Mishearings never post.
                                       #   open   = any unmatched transcript relays
                                       #   off    = freeform relay disabled; commands only
  no_repeat_ngram_size: 3              # repetition guard (GDD §5.3): forbid a repeated n-gram of
                                       # this length so noisy audio can't loop one system name
                                       # ("0-R5TS, 0-R5TS, …") at high confidence and bury the
                                       # callout. 3 is safe for real speech; 0 disables. Ignored
                                       # where the installed faster-whisper predates the param.

matching:
  phonetic_weight: 0.6                 # weight of metaphone similarity (constraint 7)
  text_weight: 0.4                     # weight of raw-text Levenshtein similarity
  full_map_fallback: true              # two-tier resolution (GDD §8.1): if a report doesn't
                                       # confidently match the SCOPED set, re-resolve against
                                       # the ENTIRE seeded k-space map so ANY real system still
                                       # resolves — the fix for a small scope / roaming corp.
                                       # Scoped accuracy is untouched (the fallback only runs
                                       # when the scoped set already failed). false = old
                                       # scoped-only behaviour.
  tiers:                               # confidence tiers — GDD §8.3
    high_min: 0.80                     # top1 >= this ...
    high_margin: 0.12                  # ... and top1 - top2 >= this → post immediately
    medium_min: 0.55                   # top1 >= this → post flagged uncertain, with buttons
  priors:                              # context reweighting — GDD §8.4
    recency_weight: 0.35               # boost for systems with recent incidents
    recency_window_min: 10             # how recent counts as recent
    proximity_weight: 0.25             # boost for systems near an active incident
    proximity_max_jumps: 5             # beyond this many jumps, no proximity boost
    reporter_history_weight: 0.15      # boost for systems this pilot reports from often
    home_weight: 0.10                  # standing boost for home and adjacent systems

incidents:
  dedupe_window_s: 90                  # same system + type within this window → fold (GDD §9.2)
  stale_after_min: 20                  # no updates for this long → auto-STALE, silently
  cancel_window_s: 30                  # "hey cortana, cancel" kills the user's last incident
  auto_resolve_min: 60                 # no updates for this long → the card auto-RESOLVES in
                                       # place, silently — no more boards full of dead cards.
                                       # Timers/form-ups exempt (they live until fires_at).
                                       # 0 = never (someone must /clear or /clearall)

discipline:
  user_cooldown_s: 30                  # min seconds between mentions from the same pilot
  circuit_breaker:
    max_mentions: 12                   # more than this many mentions ...
    window_min: 10                     # ... in this many minutes → flood control (GDD §11.1)
  personal_pings_max: 10               # max personal /pingme subscriptions per pilot (GDD §10.3)

tts:
  enabled: true                        # spoken back-channel on/off
  voice: /opt/cortana/models/piper/en_US-amy-medium.onnx  # Piper voice model
  binary: /usr/local/bin/piper         # Piper invoked as a subprocess (GDD §12 license note)
  max_utterance_s: 6                   # hard cap; longer text falls back to the short
                                       # "Posted." ack + channel text. 3 was too tight in
                                       # the field: full readbacks ("Tackled M-OEE8, code
                                       # red, posted.") got clipped to "Posted." and
                                       # pilots never heard WHAT was committed.
  effect: none                         # none | holographic (chorus+reverb "ship AI" sheen)
  personality: standard                # standard = exact GDD §12.1 lines;
                                       # cortana = acknowledgement lines rotate
                                       # ("Go ahead." / "Listening." / "Send it.")
                                       # so CORTANA feels alive; info lines never vary.
                                       # bratty = the rotation with attitude and
                                       # sailor vocabulary ("Ugh, fine. Go." /
                                       # "That was gibberish. Again.") — profanity
                                       # in ACK lines only, an adult corp's choice.
  # Ducking (60%) and talk-over suppression are fixed playback mechanics in
  # Ears (ears/src/playback.rs, GDD §12.2) — not tunables.

fun:                                   # fact library / insult maker (GDD §13.2) — OPTIONAL section
  enabled: true                        # /fact //insult + the voice "tell me a fact" / "insult"
  fact_cooldown_s: 10                  # per-guild seconds between served facts
  insult_cooldown_s: 10                # per-guild seconds between served insults
  insults_spicy: true                  # true = full sailor-mouth pool; false = clean burns only
  max_speak_s: 20                      # spoken cap for fun lines (a whole fact outruns the
                                       # tts.max_utterance_s command-reply cap)

chat:                                  # "command override" assistant (GDD §6.6) — OFF by default
  enabled: false                       # true = pilots can say "command override, <question>"
                                       # (slash twin: /ask). NEVER touches the command path.
  backend: anthropic                   # who answers: anthropic = cloud Claude (needs a key,
                                       # costs per question); local = an on-box
                                       # OpenAI-compatible server (llama.cpp/Ollama) at
                                       # local_url — the SLM lane: conversational
                                       # back-and-forth on the droplet, no API, no key, no
                                       # per-question cost. Still OFF the command path (§6).
  local_url: ""                        # backend=local endpoint, e.g.
                                       # http://127.0.0.1:8081/v1/chat/completions
                                       # (run: llama-server -m <model.gguf> --port 8081).
                                       # Empty = unset. Deploy the model+server yourself.
  model: claude-haiku-4-5              # anthropic: a Claude id — cheapest tier
                                       # (~$0.002/question); claude-opus-4-8 = ~10x smarter.
                                       # local: the model name your server expects.
  api_key_file: /etc/cortana/anthropic    # dev fallback ONLY (0600). Production reads
                                       # $CREDENTIALS_DIRECTORY/anthropic via systemd
                                       # LoadCredential= — the key is never in this file.
  max_tokens: 300                      # hard cap per answer
  user_cooldown_s: 10                  # per-pilot throttle — the cost control
  timeout_s: 25                        # wall-clock cap incl. web search
  web_search: true                     # allow 1 live web search per question
                                       # (weather etc.; each search bills ~1¢)
  answer_channel: 000000000000000000   # where answers too long to speak post.
                                       # 0 = intel_live — but chit-chat in an
                                       # intel channel annoys; point this at a
                                       # general/bot channel.

gazetteer:
  file: /etc/cortana/gazetteer.yaml       # scope rules: regions/within_jumps_of/include_all (GDD §8.1)
  home_system: Otanuomi                # anchor for the home-bias prior (§8.4) and within_jumps_of.
                                       # null (or empty) = no home system → home-bias prior off;
                                       # this is the nomadic-corp setting (GDD §8.1).
  include_all: false                   # nomadic override, mirrors gazetteer.yaml include_all —
                                       # either being true activates the entire seeded map.

areas:                                 # learned custom areas (GDD §8.5a) — OPTIONAL section, on by default
  learn: true                          # when a report names a place that resolves to no system,
                                       # CORTANA asks once ("Did you say <word>?") and, on an explicit
                                       # yes, remembers it — the corp's own place words, learned by
                                       # talking. false = post unknown places verbatim, never learn.
  max_per_guild: 200                   # cap on learned areas; at the cap learning pauses (reports
                                       # still post) until an FC prunes with /areas-forget.

nlu:                                   # LLM understanding brain (GDD §6.7) — OPTIONAL, OFF by default
  understanding: false                 # true = when the fixed grammar can't parse a callout, an
                                       # on-box model reads the transcript and returns the command,
                                       # so pilots can say it any way. The place it names is still
                                       # resolved against the real system map (no invented systems)
                                       # and nothing pings until the pilot confirms. Grammar-first:
                                       # clear callouts stay instant; only the messy ones use the model.
  url: ""                              # OpenAI-compatible endpoint of your on-box model, e.g.
                                       # http://127.0.0.1:11434/v1/chat/completions  (Ollama)
  model: ""                            # model name the server expects, e.g. llama3.2:3b
  timeout_s: 8                         # cap on one interpretation

killboard:                             # Albion Online killboard add-on — OPTIONAL, OFF by default.
                                       # A separate game module: its own SQLite file, its own poll
                                       # loop, its own /killboard commands. It never touches voice.
                                       # Enable = set `enabled: true` AND a guild AND a feed channel.
  enabled: false
  region: west                         # west | europe | east — which Albion server your guild is on
  guild_name: ""                       # resolved to an id at startup; or set guild_id directly
  guild_id: ""                         # set directly to skip name resolution
  poller:
    interval_seconds: 45               # seconds between polls (gentle on the shared, flaky API)
    request_timeout_seconds: 10
    max_retries: 3
    backoff_base_seconds: 5            # exponential: 5, 10, 20 …
    page_limit: 51                     # endpoint maximum
    max_backfill_pages: 20             # first-run history seed depth (≈ server ceiling)
    track_deaths: true                 # sweep guild DEATHS per-member (the /events guild feed
                                       # is kill-only, so Death Fame + the death feed depend on
                                       # this). Off = kills only, no death cards, Death Fame = 0.
  feed:
    kills_channel: 0                   # channel id for guild kills (0 = unset)
    deaths_channel: 0                  # channel id for guild deaths (may equal kills_channel)
    min_fame: 0                        # suppress kills below this fame from the main feed
    juicy_channel: 0                   # optional highlights channel for big kills (0 = off)
    juicy_min_fame: 2000000            # mirror to juicy when kill FAME >= this
    juicy_min_loot: 0                  # mirror to juicy when LOOT value (silver) >= this —
                                       # catches low-fame/high-loot ganks. 0 = off;
                                       # needs killboard.market.enabled. e.g. 1000000
    ignore_deaths_below_ip: 0          # skip low-IP "naked" deaths (0 = keep them)
    blob_participant_threshold: 20     # kills bigger than this are flagged blob/ZvZ
    blob_channel: 0                    # optional ZvZ channel (0 = keep in main feed)
    catchup_max_posts: 20              # cap feed posts per catch-up after downtime
    post_delay_ms: 750                 # spacing between feed messages
  cards:
    enabled: true                      # render Pillow kill-card images (false = embed only)
    icon_cache_dir: /var/lib/cortana/killboard/icons
    render_base: https://render.albiononline.com/v1
    brand_name: Dead Gaming            # footer tagline on cards (your Discord's name)
    brand_logo_path: ""                # PNG watermark; empty = bundled Dead roundel
    accent_color: "#E11212"            # card accent (#RRGGBB) — headers, rank boards
    show_loot_value: true              # print loot value on kill cards (needs market.enabled)
    daily_ranking_card: true           # attach the branded Daily Ranking image to daily posts
    reaper_watermark: true             # faint Dead reaper emblem behind the kill card
  rankings:
    timezone: UTC                      # window boundaries for daily/weekly/monthly rankings
  battles:
    channel: 0                         # optional battle-summary channel (0 = battles off)
    min_players: 20
    min_fame: 5000000
  storage:
    db_path: /var/lib/cortana/killboard/killboard.db   # the killboard's OWN db — back it up
  staleness:
    warn_after_minutes: 30             # no successful poll this long → shown in /killboard status
    no_events_notice_hours: 6          # no NEW events this long → "guild is quiet" (not an error)
  market:                              # Albion market data (AODP) — OPTIONAL, OFF by default.
                                       # Prices loot value onto kill cards + enables /market commands.
                                       # Uses the crowd-sourced Albion Online Data Project API
                                       # (host derived from killboard.region).
    enabled: false
    cache_ttl_s: 300                   # cache a price lookup this long (respects the AODP rate limit)
    request_timeout_s: 10
    default_quality: 1                 # 1 Normal · 2 Good · 3 Outstanding · 4 Excellent · 5 Masterpiece
    default_cities:                    # cities compared by /market + used to price kill loot
      - Caerleon
      - Bridgewatch
      - Lymhurst
      - Martlock
      - Fort Sterling
      - Thetford
    user_agent: "DeadBot-Killboard (self-hosted; contact your guild admin)"

routing:
  file: ""                             # routing.yaml location (GDD §10.1). "" (the default)
                                       # = a file named routing.yaml in the same directory
                                       # as this cortana.yaml.

ipc:
  socket: /run/cortana/cortana.sock          # Brain binds; Ears connects (GDD §15)
  # Ears' outbound ring size (buffer_seconds) lives in /etc/cortana/ears.yaml —
  # the ring must survive Brain restarts, so Brain cannot own that knob.

health:
  report_interval_min: 60              # cadence of #bot-health self-reports
  voice_silence_alarm_s: 60            # no VoiceTick this long with >=2 humans → degraded

database:
  path: /var/lib/cortana/cortana.db          # SQLite (WAL); backed up nightly (GDD §18)
