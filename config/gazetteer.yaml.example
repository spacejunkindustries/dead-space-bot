# CORTANA gazetteer scope — GDD §8.1 / §16. Production copy: /etc/cortana/gazetteer.yaml.
# The systems + adjacency tables are seeded from the EVE SDE (k-space) by
# `python -m cortana.nlu.seed`; these rules pick the ACTIVE subset at runtime,
# editable by the FC without touching code.
#
# Two modes:
#  - scoped (default, recommended for home-region corps): ~100–500 systems
#    scoped to the operational area via the rules below. The small set IS the
#    accuracy decision (CLAUDE.md constraint 8), not a shortcut.
#  - include_all (nomadic corps): the entire seeded (k-space) map is active so
#    ANY system in New Eden resolves. Accuracy then leans on the confirm-flow
#    (§8.3), context priors (§8.4), and alias learning (§8.5) rather than a
#    narrow candidate set. Turn it on when the corp has no fixed home.

# All-systems / nomadic mode. false (default) = scoped by the rules below.
# true = the ENTIRE seeded k-space map (~5,300 systems) is active, so ANY real
# system resolves — set this if your corp roams and reports from anywhere.
# regions/within_jumps_of are then ignored, exclude still removes, and
# within_jumps_of/home may be omitted. When you turn this on, also set
# `home_system:` to blank in cortana.yaml (no home-region bias for a roaming
# corp), and (re)seed the full map once:
#   /opt/cortana/current/venv/bin/python -m cortana.nlu.seed \
#     --db /var/lib/cortana/cortana.db
include_all: false

# ── Custom names (aliases) — call places whatever your corp calls them ───────
# A map of "what a pilot says" -> "the real system name". Case-insensitive.
# Resolved at FULL confidence BEFORE any phonetic matching, so your corp's own
# vocabulary — branch names, staging nicknames, a region's home system — just
# works. The target must be a real system name (any k-space system, even one
# outside your scope). A typo in a target is logged and skipped, never fatal.
aliases: {}
#   "the branch":     M-OEE8         # your staging in the branch
#   "tribute staging": 5ZXX-K        # what you call your Tribute foothold
#   "home":           Otanuomi
#   "the pipe":       Ahbazon

# Regions whose systems are included wholesale. (scoped mode only)
regions:
  - Kisogo-region
  - Lowsec-North

# Additionally include everything within N jumps of a system (usually home).
within_jumps_of:
  system: Otanuomi
  jumps: 8

# Systems always included regardless of region — the hubs pilots name anyway.
always_include:
  - Jita
  - Amarr
  - Rens
  - Dodixie

# Systems to drop even if a rule above matched them (e.g. phonetic collisions
# with a system the corp never visits).
exclude: []
